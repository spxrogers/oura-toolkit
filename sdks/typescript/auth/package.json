{
  "name": "@oura-toolkit/auth",
  "version": "0.2.0",
  "description": "Hand-written auth companion for @oura-toolkit/api: token store, OAuth2 refresh with rotation, and a Configuration accessToken seam",
  "repository": {
    "type": "git",
    "url": "https://github.com/spxrogers/oura-toolkit.git",
    "directory": "sdks/typescript/auth"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "test": "node --test tests/*.test.cjs",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^18",
    "typescript": "^4.9 || ^5.0"
  }
}
