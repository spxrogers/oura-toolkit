{
  "name": "@oura-toolkit/auth",
  "version": "0.1.0",
  "description": "Hand-written auth companion for @oura-toolkit/api: token store, OAuth2 refresh with rotation, and a Configuration accessToken seam",
  "repository": {
    "type": "git",
    "url": "https://github.com/spxrogers/oura-toolkit.git",
    "directory": "sdks/typescript/auth"
  },
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "test": "node --test tests/*.test.cjs",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^18",
    "typescript": "^4.9 || ^5.0"
  }
}
