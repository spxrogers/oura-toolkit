# Rust
/target

# Node (breadth SDKs, npm installer)
node_modules/

# cargo-dist output
/dist

# Derived/generated codegen artifacts — regenerate via `just spec-overlay` / `just gen`.
# The pristine vendored spec (spec/openapi.json) IS committed; overlay output is not.
/codegen/build/

# Env / secrets (tokens live in $XDG_CONFIG_HOME/oura-toolkit/, never in-repo)
.env
*.log

# Docs site (docs-site/ — Astro Starlight). Build output + Astro's cache are derived; the
# committed package-lock.json is deliberately NOT ignored (reproducible `just docs-install`).
# node_modules/ is already ignored above (any depth).
docs-site/dist/
docs-site/.astro/

# OS cruft
.DS_Store

# Python packaging artifacts (pip builds local dirs in-tree; `just sdk-check-py` /
# `just sdk-test-py` install ./sdks/python) — never commit these.
/sdks/python/build/
*.egg-info/
__pycache__/
.pytest_cache/
